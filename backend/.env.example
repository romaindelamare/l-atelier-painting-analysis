# Interfaze AI credentials and model (required for object detection)
INTERFAZE_API_KEY=your-interfaze-api-key-here
INTERFAZE_BASE_URL=https://api.interfaze.ai/v1
INTERFAZE_MODEL=interfaze-beta

# Storage / database (defaults are fine for local development)
IMAGE_DIR=./data/images
DB_URL=sqlite:///./data/paintings.db

# Number of dominant colors to extract for the palette
PALETTE_SIZE=6
