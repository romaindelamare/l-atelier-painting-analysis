# Interfaze AI credentials and model (required for object detection)
INTERFAZE_API_KEY=your-interfaze-api-key-here
INTERFAZE_BASE_URL=https://api.interfaze.ai/v1
INTERFAZE_MODEL=interfaze-beta

# Storage / database
# Use relative paths for simple local development:
IMAGE_DIR=./data/images
DB_URL=sqlite:///./data/paintings.db
# Use absolute paths to share data across git worktrees:
# IMAGE_DIR=D:/Dev/AI/l-atelier-data/images
# DB_URL=sqlite:///D:/Dev/AI/l-atelier-data/paintings.db

# Number of dominant colors to extract for the palette
PALETTE_SIZE=6

# Single-user login. AUTH_PASSWORD is your login password; AUTH_JWT_SECRET signs
# access tokens — generate a strong one with:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
# Leave either blank to disable login entirely.
AUTH_PASSWORD=change-me
AUTH_JWT_SECRET=generate-a-long-random-secret
# Optional token lifetimes (sensible defaults shown):
# ACCESS_TOKEN_TTL_MINUTES=30
# REFRESH_TOKEN_TTL_DAYS=30
